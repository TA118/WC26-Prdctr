{
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "crons": [
    { "path": "/api/send-reminder?type=week",  "schedule": "0 19 4 6 *"   },
    { "path": "/api/send-reminder?type=day",   "schedule": "0 19 10 6 *"  },
    { "path": "/api/notify-full-deadline",     "schedule": "0 18 11 6 *"  },
    { "path": "/api/notify-countdown",         "schedule": "0 8 * * 4"    },

    { "path": "/api/notify-match-reminder",    "schedule": "30 0 * * *"   },
    { "path": "/api/notify-match-reminder",    "schedule": "30 1 * * *"   },
    { "path": "/api/notify-match-reminder",    "schedule": "30 2 * * *"   },
    { "path": "/api/notify-match-reminder",    "schedule": "30 3 * * *"   },
    { "path": "/api/notify-match-reminder",    "schedule": "30 15 * * *"  },
    { "path": "/api/notify-match-reminder",    "schedule": "30 16 * * *"  },
    { "path": "/api/notify-match-reminder",    "schedule": "30 18 * * *"  },
    { "path": "/api/notify-match-reminder",    "schedule": "30 19 * * *"  },
    { "path": "/api/notify-match-reminder",    "schedule": "30 20 * * *"  },
    { "path": "/api/notify-match-reminder",    "schedule": "30 21 * * *"  },
    { "path": "/api/notify-match-reminder",    "schedule": "30 22 * * *"  },
    { "path": "/api/notify-match-reminder",    "schedule": "0 23 * * *"   },
    { "path": "/api/notify-match-reminder",    "schedule": "30 23 * * *"  }
  ]
}
